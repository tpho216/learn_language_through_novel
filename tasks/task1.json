{
  "name": "task1",
  "chapter_id": "1000",
  "chapter_zh_path": "chapters/1000_zh.txt",
  "chapter_vi_ref_path": "chapters/1000_vi.txt",
  "max_sentences": 2,
  "api_url": "http://localhost:8000/llm/analyze_chapter",
  "output_dir": "outputs",
  "enable_enrichment": true,
  "enrich_api_url": "http://localhost:8000/llm/enrich_sentence",
  "enrich_max_concurrent": 10,
  "max_enrich_sentences": 1,
  "prepare_tts_segments": true,
  "tts_api_url": "http://localhost:8000/llm/prepare_tts_segments",
  "synthesize_audio": true,
  "synthesis_api_url": "http://localhost:8000/tts/synthesize",
  "synthesis_provider": "piper",
  "synthesis_output_dir": "outputs/audio",
  "synthesis_merge_segments": true,
  "tts_selection": [
    "title.zh",
    "title.vi",
    "sentence.text_zh",
    "sentence.text_vi_ref",
    "sentence.text_vi_ai",
    "sentence.text_vi",
    "phrases[].text",
    "phrases[].meaning_vi",
    "phrases[].phrase_examples[].zh",
    "phrases[].phrase_examples[].vi",
    "phrases[].phrase_examples[].new_words[].word",
    "phrases[].phrase_examples[].new_words[].meaning_vi",
    "examples[].zh",
    "examples[].vi",
    "hanzi_explanation",
    "grammar_explanation"
  ],
  "tts_lang_cues": {
    "zh": "中文",
    "vi": "Tiếng Việt",
    "en": "English"
  },
  "tts_field_cues": {
    "title.zh": {"zh": "标题"},
    "title.vi": {"vi": "Tựa đề"},
    "sentence.text_zh": {"zh": "原文句子"},
    "sentence.text_vi": {"vi": "Câu tiếng Việt"},
    "sentence.text_vi_ref": {"vi": "Câu tiếng Việt tham khảo"},
    "sentence.text_vi_ai": {"vi": "Câu tiếng Việt AI"},
    "phrases[].text": {"zh": "词汇"},
    "phrases[].meaning_vi": {"vi": "Nghĩa tiếng Việt"},
    "phrases[].phrase_examples[].zh": {"zh": "示例"},
    "phrases[].phrase_examples[].vi": {"vi": "Ví dụ tiếng Việt"},
    "phrases[].phrase_examples[].new_words[].word": {"zh": "新词汇"},
    "phrases[].phrase_examples[].new_words[].meaning_vi": {"vi": "Nghĩa từ mới"},
    "examples[].zh": {"zh": "示例"},
    "examples[].vi": {"vi": "Ví dụ tiếng Việt"},
    "hanzi_explanation": {"zh": "", "vi": "Giải thích Hán tự"},
    "grammar_explanation": {"zh": "", "vi": "Giải thích ngữ pháp"}
  }
}
